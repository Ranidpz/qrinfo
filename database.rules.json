{
  "rules": {
    "qhunt": {
      "$codeId": {
        ".read": true,
        ".write": true
      }
    },
    "qstage": {
      "$codeId": {
        ".read": true,
        ".write": true
      }
    },
    "qchallenge": {
      "$codeId": {
        ".read": true,
        ".write": true
      }
    },
    "qtreasure": {
      "$codeId": {
        ".read": true,
        ".write": true
      }
    },
    "qgames": {
      "$codeId": {
        ".read": true,
        ".write": true,
        "viewers": {
          ".indexOn": ["joinedAt"]
        },
        "chat": {
          ".indexOn": ["sentAt"],
          "$messageId": {
            ".validate": "newData.hasChildren(['senderId', 'senderNickname', 'text', 'sentAt', 'phraseType']) && newData.child('text').isString() && newData.child('text').val().length <= 200 && newData.child('senderNickname').isString() && newData.child('senderNickname').val().length <= 30 && newData.child('senderId').isString() && newData.child('sentAt').isNumber() && newData.child('phraseType').isString()"
          }
        },
        "chatBans": {
          "$visitorId": {
            ".validate": "newData.hasChildren(['visitorId', 'bannedAt']) && newData.child('bannedAt').isNumber() && newData.child('visitorId').isString() && newData.child('visitorId').val().length <= 50"
          }
        }
      }
    }
  }
}
